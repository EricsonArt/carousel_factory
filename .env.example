# Skopiuj ten plik jako .env i wypelnij swoje klucze.
# Lub zostaw .env i utworz .streamlit/secrets.toml (priorytet 1).

# WYMAGANE w Phase 1
ANTHROPIC_API_KEY=          # console.anthropic.com - dla Claude (copy + vision)
OPENAI_API_KEY=             # platform.openai.com - dla GPT Image generation

# OPCJONALNE - cascade fallback (Phase 3)
GEMINI_API_KEY=             # ai.google.dev - dla Gemini 2.5 Flash Image (Nano Banana)
REPLICATE_API_TOKEN=        # replicate.com - tani fallback FLUX

# OPCJONALNE - scraping inspiracji z URL (Phase 2)
APIFY_API_TOKEN=            # apify.com - scrapowanie TT/IG postow

# AUTO-PUBLISH (Phase 2 - instagrapi MVP)
INSTAGRAM_USERNAME=         # twoj IG username (osobiste konto, ryzyko bana przy >2/dzien)
INSTAGRAM_PASSWORD=

# AUTO-PUBLISH (Phase 3 - oficjalne API, do 25+/dzien bez bana)
IG_USER_ID=                 # IG Business Account ID (z Meta Developer)
IG_ACCESS_TOKEN=            # long-lived access token z Instagram Graph API
TT_CLIENT_KEY=              # TikTok Developer App
TT_CLIENT_SECRET=
TT_ACCESS_TOKEN=

# COST CONTROL
DAILY_COST_CAP_USD=5.0      # hard limit dziennych kosztow image-gen
PUBLISHER_MODE=none         # none | instagrapi | graph_api | tiktok

# PUBLICZNY DEPLOY - WYMAGANE gdy wystawiasz na URL (cloudflared/ngrok/Streamlit Cloud)
# Bez tego ktokolwiek z URLem moze generowac karuzele i kosztowac Cie pieniadze!
APP_PASSWORD=               # ustaw jakies dlugie haslo, np. moje_super_haslo_2026
